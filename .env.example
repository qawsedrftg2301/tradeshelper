# Required: MongoDB connection string
# For local development, use: mongodb://127.0.0.1:27017/tradeshelper  
# For production (Vercel), use MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/tradeshelper?retryWrites=true&w=majority

# Optional: Port for local development
PORT=3000

# Optional: JWT secret for token signing (if you add JWT auth later)
# JWT_SECRET=your_jwt_secret_here
